---
import { SITE } from "@consts";

const { pathname } = Astro.url;
// Helper to check if a link is active
const isActive = (path: string) => pathname.includes(path);
---

<header class="py-6 border-b border-zinc-100 dark:border-zinc-800">
  <div class="container-content flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between font-mono text-[13px] tracking-tight">
    
    <div class="flex items-center gap-2 min-w-0">
      <a href="/" class="text-zinc-500 no-underline hover:text-black dark:hover:text-white transition-colors">
        eliana.lol
      </a>
      {pathname.includes('/notes') && (
        <>
          <span class="text-zinc-300 dark:text-zinc-700">/</span>
          <span class="text-black dark:text-white">notes</span>
        </>
      )}
    </div>

    <nav class="flex items-center gap-4 text-zinc-400 overflow-x-auto no-scrollbar sm:overflow-visible pb-1 sm:pb-0">
      <a href="/gallery" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/gallery') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>gallery</a>
      <a href="/guides" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/guides') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>guides</a>
      <a href="/tools" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/tools') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>tools</a>
      <a href="/links" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/links') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>links</a>
      <a href="/lists" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/lists') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>lists</a>
      <a href="/notes" class:list={["no-underline transition-colors whitespace-nowrap", isActive('/notes') ? "text-black dark:text-white" : "hover:text-zinc-800 dark:hover:text-zinc-200"]}>notes</a>
      
      <button 
        id="theme-toggle" 
        aria-label="Toggle theme"
        class="ml-2 px-2 py-0.5 border border-zinc-200 dark:border-zinc-700 rounded text-[11px] hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-colors shrink-0"
      >
        <span class="theme-label">light</span>
      </button>
    </nav>
  </div>
</header>

<style>
  /* Hide scrollbar for the mobile nav scroll */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script is:inline>
  function setupTheme() {
    const toggleBtn = document.getElementById("theme-toggle");
    const label = toggleBtn?.querySelector(".theme-label");
    const html = document.documentElement;

    if (!toggleBtn || !label) return;

    const updateUI = () => {
      const isDark = html.classList.contains("dark");
      label.innerText = isDark ? "dark" : "light";
    };

    // Set initial state
    updateUI();

    toggleBtn.addEventListener("click", () => {
      const isDark = html.classList.toggle("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateUI();
    });
  }

  setupTheme();
  document.addEventListener("astro:after-swap", setupTheme);
</script>