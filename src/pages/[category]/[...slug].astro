---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const categories = [
    "blog", "notes", "guides", "tools", "recipes", "research", 
    "lists", "links", "favorite", "post", "archive", "computer", 
    "series", "packages", "blogroll", "projects", "work", "gallery", "pages"
  ];

  const allPaths = await Promise.all(
    categories.map(async (category) => {
      const entries = await getCollection(category as any);
      return entries.map((entry) => ({
        params: { category, slug: entry.slug },
        props: { entry },
      }));
    })
  );

  return allPaths.flat();
}

type Props = {
  entry: CollectionEntry<any>;
};

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<PageLayout title={entry.data.title || entry.slug} description={entry.data.description || ""}>
  <div class="container">
    <div class="animate">
      <BackToPrev href={`/${entry.collection}`}>
        Back to {entry.collection}
      </BackToPrev>
    </div>

    <div class="space-y-1 my-10">
      <div class="animate">
        <h1 class="text-3xl font-semibold text-black dark:text-white">
          {entry.data.title || entry.slug.replace(/-/g, ' ')}
        </h1>
      </div>
    </div>

    <article class="animate prose dark:prose-invert max-w-none">
      <Content />
    </article>
  </div>
</PageLayout>