---
import { getCollection, type CollectionKey } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import { formatDate } from "../../lib/utils"; // Fixed the path error from earlier!

export async function getStaticPaths() {
  const categories: CollectionKey[] = [
    "blog", "notes", "guides", "tools", "recipes", "research", 
    "lists", "links", "favorite", "projects", "work", "archive"
  ];

  const paths = await Promise.all(
    categories.map(async (category) => {
      const entries = await getCollection(category as any);
      return entries.map((entry) => ({
        params: { category, slug: entry.slug },
        props: { entry },
      }));
    })
  );

  return paths.flat();
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<PageLayout title={entry.data.title} description={entry.data.description}>
  <article class="animate">
    <div class="flex items-center gap-2 font-mono text-[12px] text-zinc-400 mb-8">
      <a href={`/${Astro.params.category}`} class="hover:text-[var(--color-accent)]">
        {Astro.params.category}
      </a>
      <span>/</span>
      <span class="text-zinc-800 dark:text-zinc-200">{entry.data.title}</span>
    </div>

    <header class="mb-12">
      <h1 class="text-3xl font-medium mb-2">{entry.data.title}</h1>
      <div class="flex gap-2 text-sm text-zinc-500 font-mono">
        <time datetime={entry.data.date.toISOString()}>
          {formatDate(entry.data.date)}
        </time>
        {entry.data.maturity && (
          <>
            <span>•</span>
            <span class="capitalize">{entry.data.maturity}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</PageLayout>