---
import { getCollection } from "astro:content";
import type { CollectionEntry, CollectionKey } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";

export async function getStaticPaths() {
  // Explicitly casting the array to CollectionKey[] to satisfy Astro's type system
  const categories: CollectionKey[] = [ 
    "notes", "guides", "tools", "recipes", "research", 
    "lists", "links", "favorite", "archive", "computer", 
    "series", "packages", "blogroll", "gallery", "post"
  ];

  return categories.map(category => ({
    params: { category },
    props: { categoryName: category }
  }));
}

const { category } = Astro.params;
const { categoryName } = Astro.props;

// 1. Fetch entries and cast them
const allEntries = (await getCollection(category as any)) as CollectionEntry<any>[];

// 2. Sort the entries (This was missing!)
const sortedEntries = allEntries
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 3. Define the groups (This was missing!)
const groups = [
  { id: "evergreen", emoji: "🌲", label: "Evergreen", color: "var(--color-accent-alt)" },
  { id: "budding", emoji: "🌿", label: "Budding", color: "var(--color-accent-yellow)" },
  { id: "seedling", emoji: "🌱", label: "Seedling", color: "var(--color-accent)" }
];
---

<PageLayout title={categoryName} description={`my curated collection of ${categoryName}`}>
  <div class="container-prose py-12">
    <div class="flex items-center gap-2 font-mono text-[12px] text-zinc-400 mb-4">
      <a href="/" class="hover:text-[var(--color-accent)]">home</a>
      <span>/</span>
      <span class="text-zinc-800 dark:text-zinc-200">{categoryName}</span>
    </div>

    <h1 class="text-[40px] font-medium mb-12 lowercase">{categoryName}</h1>
    
    <div id="notes-container">
      {groups.map(group => {
        // Now 'sortedEntries' is defined, so this filter will work
        const groupNotes = sortedEntries.filter(n => n.data.maturity === group.id);
        
        return groupNotes.length > 0 && (
          <section class="mb-12">
            <h2 style={`color: ${group.color}`} class="font-mono text-[11px] uppercase tracking-widest mb-4 flex items-center gap-2">
              <span>{group.emoji}</span>
              <span>{group.label}</span>
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {groupNotes.map(note => (
                <a href={`/${category}/${note.slug}`} class="block p-4 border border-zinc-100 dark:border-zinc-800 rounded-lg hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-all no-underline group">
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <h3 class="text-[15px] font-normal group-hover:text-[var(--color-accent)] transition-colors leading-snug">
                      {note.data.title}
                    </h3>
                  </div>
                  <span class="font-mono text-[11px] text-zinc-400 tabular-nums">
                    {note.data.date.toLocaleDateString("en-US", { 
                      month: 'short', 
                      day: '2-digit', 
                      year: 'numeric' 
                    })}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )
      })}

      {sortedEntries.length === 0 && (
        <div class="py-20 text-center border border-dashed border-zinc-200 dark:border-zinc-800 rounded-lg">
          <p class="text-zinc-400 font-mono text-sm">this garden bed is currently empty.</p>
        </div>
      )}
    </div>
  </div>
</PageLayout>