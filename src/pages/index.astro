---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";
import { Icon } from "astro-icon/components";

const collectionsToFetch = [
  "blog", "notes", "guides", "tools", "recipes", "research", 
  "lists", "links", "favorite", "post", "archive", "computer", 
  "series", "packages", "blogroll"
];

const allCollections = await Promise.all(
  collectionsToFetch.map((name) => getCollection(name as any)),
);

const posts = (allCollections.flat() as any[])
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const titleA = (a.data.title || a.slug).toLowerCase();
    const titleB = (b.data.title || b.slug).toLowerCase();
    return titleA.localeCompare(titleB);
  })
  .slice(0, 10);
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>
  <div class="space-y-16">
    <section class="animate space-y-4">
      <h1>hi, i'm eliana (✿◠‿◠)</h1>
      <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400">
        𓆝 𓆟 𓆞 𓆟 𓆝 𓆟 𓆞 𓆟 𓆝 𓆟 𓆞 𓆟 𓆝 𓆟 𓆞 𓆟 𓆝
      </div>
      <p class="max-w-prose leading-relaxed text-zinc-600 dark:text-zinc-400 pt-4">
        welcome to my digital garden. i use python, web scraping, and obsidian
        frequently to organize and catalog information.
      </p>
      <div class="flex gap-5 text-zinc-400 pt-6">
        <a href="https://github.com/jubilancy" aria-label="github" class="hover:text-black dark:hover:text-white transition-colors">
          <Icon name="lucide:github" class="size-5" />
        </a>
        <a href="/rss.xml" aria-label="rss feed" class="hover:text-black dark:hover:text-white transition-colors">
          <Icon name="lucide:rss" class="size-5" />
        </a>
      </div>
    </section>

    <hr class="border-zinc-100 dark:border-zinc-800" />

    <section class="animate space-y-6">
      <div class="flex justify-between items-baseline">
        <h2 class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400">Latest</h2>
        <a href="/notes" class="font-mono text-[11px] text-zinc-400 hover:text-black dark:hover:text-white transition-colors">
          view all →
        </a>
      </div>

      <ul class="divide-y divide-zinc-100 dark:divide-zinc-800 border-t border-zinc-100 dark:border-zinc-800">
        {posts.map((post) => (
          <li class="group py-3">
            <a href={`/${post.collection}/${post.slug}`} class="flex justify-between items-baseline no-underline">
              <div class="flex items-baseline overflow-hidden">
                <span class="text-[17px] text-black dark:text-white group-hover:text-[var(--color-accent)] transition-colors truncate">
                  {post.data.title || post.slug.replace(/-/g, ' ')}
                </span>
                <span class="text-zinc-300 dark:text-zinc-700 mx-2 text-[12px] font-mono lowercase shrink-0">
                  ↗ {post.collection}
                </span>
              </div>
              <span class="text-zinc-300 dark:text-zinc-700 text-xs font-mono">view</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</PageLayout>